      "title": "Event Pipeline",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Events Processed Rate (by coin)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "rate(events_processed_total[1m])",
          "legendFormat": "{{coin}}", "range": true, "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Event Processing Duration",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.50, sum by(le)(rate(event_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p50", "range": true, "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.95, sum by(le)(rate(event_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95", "range": true, "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.99, sum by(le)(rate(event_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p99", "range": true, "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "description": "Política A (3 consumers, ≈0) vs Política B (1 consumer, puede acumularse bajo picos).",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "redpanda_kafka_consumer_group_lag{group=\"coingecko-consumer-group\"}",
          "legendFormat": "lag [partition {{partition}}]", "refId": "A"
        }
      ]
    },
