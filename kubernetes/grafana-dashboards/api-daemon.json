      "id": 1,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "sum by(method, endpoint)(rate(http_requests_total{service_name=\"api-daemon\"}[1m]))",
          "legendFormat": "{{method}} {{endpoint}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate 5xx (req/s)",
