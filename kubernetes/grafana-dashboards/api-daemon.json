      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "sum(rate(http_requests_total{service_name=\"api-daemon\",status_code=~\"5..\"}[1m])) or (sum(rate(http_requests_total{service_name=\"api-daemon\",status_code=\"200\"}[1m])) * 0)",
