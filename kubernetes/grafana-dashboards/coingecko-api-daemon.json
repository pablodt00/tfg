        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "autoscaler_requested_pods{configuration_name=\"coingecko-service\"}",
          "legendFormat": "__auto", "refId": "A"
        }
      ]
    },
    {
      "id": 7,
