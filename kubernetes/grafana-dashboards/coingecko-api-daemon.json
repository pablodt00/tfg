  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CoinGecko External API",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CoinGecko API Call Rate (calls/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "rate(coingecko_api_requests_total[1m])",
          "legendFormat": "calls/s", "range": true, "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CoinGecko API Call Latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}},
        "overrides": []
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.50, sum by(le)(rate(coingecko_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50", "range": true, "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.95, sum by(le)(rate(coingecko_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95", "range": true, "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "histogram_quantile(0.99, sum by(le)(rate(coingecko_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99", "range": true, "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Autoscaler",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Pods",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 80}]}
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "ff9qt6ns2x340f"},
          "expr": "autoscaler_actual_pods{configuration_name=\"coingecko-service\"}",
          "legendFormat": "__auto", "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
